{
  "compilerOptions": {
    "target": "ES2021",
    "lib": ["ES2021", "WebWorker", "WebWorker.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "types": []
  },
  "include": ["src/sw.ts", "src/data/version.ts"]
}
